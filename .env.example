# Auth.js — Google OAuth (restricted to @vammo.com)
# Generate AUTH_SECRET: openssl rand -base64 32
AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Set to your production URL in Vercel (not needed locally)
# AUTH_URL=https://vammo-grid.vercel.app

# Metabase — server-side only, never exposed to the browser
METABASE_URL=https://metabase.vammo.com
METABASE_API_KEY=

# Metabase question IDs
# #29571 uses Maestro OS consumption for DOH (replaces #27759 IMS-ledger DOH)
METABASE_QUESTION_INVENTORY=29571
# Daily consumption per item per hub from Maestro OS (question #29567)
METABASE_QUESTION_CONSUMPTION=29567

# DOH thresholds (days)
DOH_WARNING_THRESHOLD=14
DOH_CRITICAL_THRESHOLD=7

# Supabase — Vammo Automations project (inventory snapshots)
# NEXT_PUBLIC_ prefix exposes to the browser (safe — anon key + RLS)
NEXT_PUBLIC_SUPABASE_URL=https://jfdqlnpidynxwqqiblcd.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImpmZHFsbnBpZHlueHdxcWlibGNkIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NDE1NDAxNjcsImV4cCI6MjA1NzExNjE2N30.ADfXbcve4R7Fyp0OjFY29OmXOaJxBgIHG146yrmhzU0
# Server-side only — get from Supabase dashboard → Project Settings → API
SUPABASE_SERVICE_ROLE_KEY=

# Cron secret — protects POST /api/inventory/snapshot
# Vercel auto-injects this when cron jobs are enabled; also set manually for local testing
CRON_SECRET=

# ClickHouse — V2 only, leave blank for V1
CLICKHOUSE_HOST=
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=

# Auth.js — Google OAuth (restricted to @vammo.com)
# Generate AUTH_SECRET: openssl rand -base64 32
AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Set to your production URL in Vercel (not needed locally)
# AUTH_URL=https://vammo-grid.vercel.app

# Metabase — server-side only, never exposed to the browser
METABASE_URL=https://metabase.vammo.com
METABASE_API_KEY=

# Metabase question IDs
METABASE_QUESTION_INVENTORY=27759
# TBD — set once weekly SO consumption question is created in Metabase
METABASE_QUESTION_CONSUMPTION=

# DOH thresholds (days)
DOH_WARNING_THRESHOLD=14
DOH_CRITICAL_THRESHOLD=7

# ClickHouse — V2 only, leave blank for V1
CLICKHOUSE_HOST=
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=

# Auth.js — Google OAuth (restricted to @vammo.com)
# Generate AUTH_SECRET: openssl rand -base64 32
AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Set to your production URL in Vercel (not needed locally)
# AUTH_URL=https://vammo-grid.vercel.app

# DOH thresholds (days)
DOH_WARNING_THRESHOLD=14
DOH_CRITICAL_THRESHOLD=7

# Cron secret — protects the Vercel cron routes (POST /api/recovery/refresh,
# POST /api/orders/sync). Vercel auto-injects this when cron jobs are enabled;
# also set manually for local testing.
CRON_SECRET=

# Analytics warehouse — direct ClickHouse (required; the Metabase REST fallback was
# retired). The planning platform reads stock/forecast/ledger/alerts from here, AND
# (since decisions.MD #11 — Supabase fully removed) reads/writes the editable fleet
# config tables (dev.fleet_sku_policy, dev.fleet_purchase_order, dev.fleet_part_compat,
# dev.fleet_info, dev.fleet_job_run, dev.fleet_audit_log). This user needs CREATE
# TABLE + INSERT + SELECT on `dev.*`, not just SELECT.
CLICKHOUSE_HOST=
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=

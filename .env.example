# Auth.js — Google OAuth (restricted to @vammo.com)
# Generate AUTH_SECRET: openssl rand -base64 32
AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Set to your production URL in Vercel (not needed locally)
# AUTH_URL=https://vammo-grid.vercel.app

# Metabase — server-side only, never exposed to the browser
METABASE_URL=https://your-metabase-instance.example.com
METABASE_API_KEY=

# Metabase question IDs (get from your Metabase question URLs)
METABASE_QUESTION_INVENTORY=
METABASE_QUESTION_CONSUMPTION=

# DOH thresholds (days)
DOH_WARNING_THRESHOLD=14
DOH_CRITICAL_THRESHOLD=7

# Supabase — get from Supabase dashboard → Project Settings → API
# NEXT_PUBLIC_ prefix exposes to the browser (safe — anon key + RLS)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Server-side only — get from Supabase dashboard → Project Settings → API
SUPABASE_SERVICE_ROLE_KEY=

# Cron secret — protects POST /api/inventory/snapshot
# Vercel auto-injects this when cron jobs are enabled; also set manually for local testing
CRON_SECRET=

# n8n ingest secret — protects POST /api/orders/ingest (purchase orders from n8n)
# Generate: openssl rand -base64 32. Send it as: Authorization: Bearer <value>
N8N_INGEST_SECRET=

# ClickHouse — V2 only, leave blank for V1
CLICKHOUSE_HOST=
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=
